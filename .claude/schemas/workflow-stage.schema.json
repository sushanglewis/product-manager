{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lincoln-framework.dev/schemas/workflow-stage.schema.json",
  "title": "Lincoln Workflow Stage State Schema",
  "description": "Validates branch-scoped workflow-stage.yaml files that track stage progression in append-only node history.",
  "type": "object",
  "required": ["schema_version", "workflow", "current_run", "nodes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "workflow": {
      "type": "object",
      "required": ["name", "version", "template"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "template": { "type": "string" }
      }
    },
    "current_run": {
      "type": "object",
      "required": ["run_id", "branch", "current_stage", "status", "variables"],
      "properties": {
        "run_id": { "type": "string" },
        "branch": { "type": "string" },
        "current_stage": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "paused", "waiting_for_human", "validation_failed", "completed"]
        },
        "started_at": { "type": "string" },
        "last_updated_at": { "type": "string" },
        "variables": {
          "type": "object",
          "properties": {
            "session_id": { "type": "string" },
            "design_id": { "type": "string" },
            "change_name": { "type": "string" },
            "issue_number": { "type": "string" },
            "pr_number": { "type": "string" },
            "feature_slug": { "type": "string" }
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/nodeEntry" }
    },
    "recovery": {
      "type": "object",
      "properties": {
        "last_validated_checkpoint": { "type": "string" },
        "can_resume_from": { "type": "string" },
        "abort_reason": { "type": ["string", "null"] },
        "abort_at": { "type": ["string", "null"] }
      }
    }
  },
  "definitions": {
    "nodeEntry": {
      "type": "object",
      "required": ["node_id", "status"],
      "properties": {
        "node_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "paused", "waiting_for_human", "validation_failed", "completed", "pr_submitted", "merged"]
        },
        "started_at": { "type": "string" },
        "completed_at": { "type": "string" },
        "handoff_file": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gate_passed": { "type": "boolean" },
        "approved_by": { "type": "string" }
      }
    }
  }
}
