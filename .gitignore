# Synced external agent definitions (manifests and sync script are committed)
.claude/agents/external/*/
!.claude/agents/external/.gitkeep

# Audio and video recordings (large files)
recordings/*
!recordings/.gitkeep

# Interview artifacts (can be large or contain sensitive content)
interviews/*
!interviews/.gitkeep

# OpenSpec changes are committed for review and CI validation.

# Context state files
.context/

# Visual companion session artifacts
.superpowers/

# Obsidian personal workspace settings
docs/knowledge/.obsidian/workspace.json
docs/knowledge/.obsidian/graph.json

# macOS
.DS_Store

# Python virtual environments
.venv/
venv/

# Common build artifacts
node_modules/
__pycache__/
*.pyc
*.log
.omc/
